USE_REAL_LLM=false

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

CLAUDE_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o

LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
LLM_MAX_RETRIES=3

INCONSISTENCY_MAX_GROUP_SIZE=20
